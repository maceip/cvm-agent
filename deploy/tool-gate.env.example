# Copy to tool-gate.env and fill in. Secrets stay on the tool-gate host only.

# --- eat-pass (generate once: openssl rand -hex 32) ---
EATPASS_ATTESTER_SEED=
EATPASS_KT_SEED=
EATPASS_ADMIN_TOKEN=

# Attester verifies hardware EAT; issuer only blind-signs on authorization.
# After first attester start, set ATTESTER_PUB from GET http://127.0.0.1:8087/pubkey
ATTESTER_PUB=

# Attester verification policy (replaces legacy --allow).
# Option A: path to VerificationPolicy JSON (see deploy/policies/)
# POLICY_FILE=deploy/policies/uqaz1-azure.example.json
# Option B: generate from SNP launch measurement hex (eat-pass-gate allow list)
ALLOW_VALUE_X=
# Option C: generate from cvm-agent registry entry
# REGISTRY_ENTRY=registry/8c9587c0981d7878.json
ATTESTER_GATE=azure
# Optional: verify policy.json.sig (CoRIM-style sidecar; Ferro ITASEC 2024)
# EATPASS_POLICY_TRUSTED_PUB=<64-hex FAEST-128f pub>,...

# Pin the KT log key (printed by issuer on startup: kt log pubkey)
KT_LOG_PUB=

# --- tool-gate mailbox (never on the agent) ---
TOOL_GATE_SMTP_HOST=smtp.gmail.com
TOOL_GATE_SMTP_PORT=587
TOOL_GATE_SMTP_USER=you@gmail.com
TOOL_GATE_IMAP_PASSWORD=your-app-password
TOOL_GATE_FROM=you@gmail.com

# Named contacts for demos: cvm tool send-email --to ryan
TOOL_GATE_CONTACT_RYAN=ryan@example.com
TOOL_GATE_ALLOWED_TO=ryan@example.com

# Set to 1 for demo without sending real mail
# TOOL_GATE_DRY_RUN=1

# --- listen / TLS (production: use real certs on 0.0.0.0) ---
LISTEN_TOOL_GATE=127.0.0.1:8787
LISTEN_ATTESTER=127.0.0.1:8087
LISTEN_ISSUER=127.0.0.1:8088
LISTEN_REDEEMER=127.0.0.1:8100

# TLS_CERT=
# TLS_KEY=

# Paths to release binaries (override if not on PATH)
# EAT_PASS_BIN=/path/to/eat-pass
# TOOL_GATE_BIN=/path/to/tool-gate
# CVM_BIN=/path/to/cvm
